  "chunk_length": 5424,
  "target_count": 4,
  "raw_text": "[\n{\n  \"type\": \"concept\",\n   \"difficulty\": 4,\n   \"front\": \"What is the main difference between browser-based AI and AI native to the platform?\",\n   \"back\": \"Browser-based AI starts from scratch every time, while AI native to the platform can access and build upon previous knowledge and context.\",\n   \"insight\": \"The power of local context and how it shifts the way we interact with AI.\",\n   \"mistake\": \"The common misconception that AI is limited to chat prompts and forgets previous conversations.\",\n   \"example\": \"Imagine working on a project with multiple conversations, where you can build upon previous ideas and context.\"\n},\n\n{\n   \"type\": \"mcq\",\n   \"difficulty\": 4,\n   \"front\": \"What is the primary advantage of working with a context file in Claude Code?\",\n   \"options\": [\"A. It allows me to repeat myself constantly\", \"B. It enables me to provide generic advice\", \"C. It helps me maintain a living knowledge base that Claude reads from\", \"D. It prevents me from updating files\"],\n   \"correctAnswer\": \"C. It helps me maintain a living knowledge base that Claude reads from\",\n   \"back\": \"Context files allow you to maintain a living knowledge base that Claude can read from, enabling it to provide more accurate and relevant information.\",\n   \"insight\": \"The importance of local context in AI-powered interactions.\",\n   \"mistake\": \"The misconception that context files are unnecessary or that they only serve as a substitute for human memory.\",\n   \"example\": \"Think of a context file as a dynamic notebook that Claude can read from, allowing you to build upon previous ideas and context.\"\n},\n\n{\n   \"type\": \"concept\",\n   \"difficulty\": 4,\n   \"front\": \"What is a context file?\",\n   \"back\": \"A context file is a markdown file that contains information that Claude should know, such as company mission and values, project descriptions, or meeting notes.\",\n   \"insight\": \"The role of context files in maintaining a living knowledge base and enabling more effective AI-powered interactions.\",\n   \"mistake\": \"The common misconception that context files are only for storing generic information.\",\n   \"example\": \"Imagine creating a context file for a project, where you can store relevant information, such as project goals, timelines, and key decisions.\"\n},\n\n{\n   \"type\": \"problem\",\n   \"difficulty\": 4,\n   \"front\": \"Exercise 1.1: Read from local context\",\n   \"back\": \"Create a new file called 'random.md' in your Brain folder, write a few paragraphs about anything, and then switch to Claude Code to read the file and summarize the key ideas.\",\n   \"insight\": \"The process of creating and using context files to enhance AI-powered interactions.\",\n   \"mistake\": \"The common mistake of not properly organizing context files, leading to confusion and inefficiency.\",\n   \"example\": \"Think of a context file as a dynamic notebook that Claude can read from, allowing you to build upon previous ideas and context.\"\n}\n]"
}
